{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibefactory.io/schemas/metrics.schema.json",
  "title": "Vibefactory Metrics",
  "type": "object",
  "required": ["lastUpdated", "week", "seo", "geo", "aeo", "content", "history"],
  "properties": {
    "lastUpdated": { "type": "string", "format": "date" },
    "week": { "type": "string", "pattern": "^\\d{4}-W\\d{2}$" },
    "seo": {
      "type": "object",
      "required": ["googleIndexedPages", "avgPosition", "totalImpressions", "totalClicks", "ctr", "sitemapUrls", "robotsTxtValid"],
      "properties": {
        "googleIndexedPages": { "type": "integer", "minimum": 0 },
        "avgPosition": { "type": "number", "minimum": 0 },
        "totalImpressions": { "type": "integer", "minimum": 0 },
        "totalClicks": { "type": "integer", "minimum": 0 },
        "ctr": { "type": "number", "minimum": 0, "maximum": 100 },
        "sitemapUrls": { "type": "integer", "minimum": 0 },
        "robotsTxtValid": { "type": "boolean" }
      }
    },
    "geo": {
      "type": "object",
      "required": ["perplexityCitations", "chatgptMentions", "bingCopilotMentions", "llmsTxtCrawls", "llmsFullTxtCrawls", "aiOverviewAppearances"],
      "properties": {
        "perplexityCitations": { "type": "integer", "minimum": 0 },
        "chatgptMentions": { "type": "integer", "minimum": 0 },
        "bingCopilotMentions": { "type": "integer", "minimum": 0 },
        "llmsTxtCrawls": { "type": "integer", "minimum": 0 },
        "llmsFullTxtCrawls": { "type": "integer", "minimum": 0 },
        "aiOverviewAppearances": { "type": "integer", "minimum": 0 }
      }
    },
    "aeo": {
      "type": "object",
      "required": ["feedXmlValid", "structuredDataPages", "faqSchemaPages", "articleSchemaPages", "avgAnswerBoxEligibility"],
      "properties": {
        "feedXmlValid": { "type": "boolean" },
        "structuredDataPages": { "type": "integer", "minimum": 0 },
        "faqSchemaPages": { "type": "integer", "minimum": 0 },
        "articleSchemaPages": { "type": "integer", "minimum": 0 },
        "avgAnswerBoxEligibility": { "type": "string", "enum": ["none", "low", "medium", "high"] }
      }
    },
    "content": {
      "type": "object",
      "required": ["totalArticles", "categoryCoverage", "avgReadTime", "publishingCadence"],
      "properties": {
        "totalArticles": { "type": "integer", "minimum": 0 },
        "categoryCoverage": { "type": "object", "additionalProperties": { "type": "integer" } },
        "avgReadTime": { "type": "string" },
        "publishingCadence": { "type": "string" }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["week", "googleIndexedPages", "totalImpressions", "totalClicks", "perplexityCitations", "chatgptMentions", "totalArticles"],
        "properties": {
          "week": { "type": "string", "pattern": "^\\d{4}-W\\d{2}$" },
          "googleIndexedPages": { "type": "integer" },
          "totalImpressions": { "type": "integer" },
          "totalClicks": { "type": "integer" },
          "perplexityCitations": { "type": "integer" },
          "chatgptMentions": { "type": "integer" },
          "totalArticles": { "type": "integer" }
        }
      }
    }
  }
}
