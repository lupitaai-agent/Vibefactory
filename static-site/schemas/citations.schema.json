{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibefactory.io/schemas/citations.schema.json",
  "title": "Vibefactory Citations",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["date", "source", "query", "articleCited", "snippetUsed", "verified"],
    "properties": {
      "date": { "type": "string", "format": "date" },
      "source": { "type": "string", "enum": ["Perplexity", "ChatGPT", "Bing Copilot", "Google AI Overview"] },
      "query": { "type": "string" },
      "articleCited": { "type": "string" },
      "snippetUsed": { "type": "string" },
      "verified": { "type": "boolean" }
    }
  }
}
