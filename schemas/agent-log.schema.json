{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibefactory.io/schemas/agent-log.schema.json",
  "title": "Vibefactory Agent Log",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["timestamp", "agent", "action", "description", "files"],
    "properties": {
      "timestamp": { "type": "string", "format": "date-time" },
      "agent": { "type": "string" },
      "action": {
        "type": "string",
        "enum": [
          "metrics-update", "content-publish", "seo-optimization",
          "geo-optimization", "aeo-optimization", "experiment-start",
          "experiment-end", "ab-test-start", "ab-test-end",
          "crawl-check", "citation-check", "content-gap-add",
          "sprint-create", "validation-run"
        ]
      },
      "description": { "type": "string" },
      "files": { "type": "array", "items": { "type": "string" } }
    }
  }
}
