{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibefactory.io/schemas/content-gaps.schema.json",
  "title": "Vibefactory Content Gaps",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["topic", "category", "estimatedSearchVolume", "priority", "status", "rationale", "addedDate"],
    "properties": {
      "topic": { "type": "string" },
      "category": { "type": "string", "enum": ["AI", "Security", "Sustainability", "Crypto", "Tech", "Freediving", "Economy", "Robotics"] },
      "estimatedSearchVolume": { "type": "string", "enum": ["low", "medium", "high"] },
      "priority": { "type": "string", "enum": ["low", "medium", "high"] },
      "status": { "type": "string", "enum": ["backlog", "planned", "research", "writing", "published"] },
      "rationale": { "type": "string" },
      "addedDate": { "type": "string", "format": "date" }
    }
  }
}
