# SECURITY - Sensitive files
*.key
*.secret
*.pem
*.p12
*.pfx
*.env
*.env.*
.envrc
.secrets
*credentials*
*password*
*api-key*
*apikey*
*token*
*certificate*

# Configuration files
*.conf
*.config
*.ini
*.yaml
*.yml
*.json
*.toml
# Except sitemap.xml (needed for SEO)
!sitemap.xml

# All markdown files (may contain notes)
*.md

# Logs and data
logs/
*.log
data/
database/
*.db
*.sqlite
# Except robots.txt (needed for SEO)
!robots.txt

# Development files
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Directories that should never be public
config/
memory/
private/
secrets/
temp/
tmp/

# Backup files
*.bak
*.backup
*.old
*.orig
*.tmp

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build artifacts
build/
dist/
target/
